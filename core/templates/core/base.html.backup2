<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Ericsson Log Analyzer{% endblock %}</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --ericsson-blue: #0F4C81;
            --ericsson-dark: #0A2D4A;
        }
        body { background-color: #f0f2f5; }
        .navbar { background: linear-gradient(135deg, var(--ericsson-dark), var(--ericsson-blue)); }
        .navbar-brand { font-weight: 700; font-size: 1.1rem; letter-spacing: 0.5px; }
        .card { border: none; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
        .card-header { border-radius: 10px 10px 0 0 !important; }
        .stat-card { transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-3px); }
        .table thead th { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.5px; }
        .badge-critical { background-color: #dc3545; }
        .badge-major { background-color: #fd7e14; }
        .badge-minor { background-color: #ffc107; color: #000; }
        .row-critical { background-color: #fff0f0 !important; }
        .row-warning  { background-color: #fff9e6 !important; }
        .row-ok       { background-color: #f0fff4 !important; }
        .footer-bar { background: var(--ericsson-dark); color: rgba(255,255,255,0.6); font-size: 0.8rem; }
    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="/dashboard/">
            <i class="bi bi-reception-4 me-2"></i>Ericsson Log Analyzer
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link {% if request.path == '/' %}active{% endif %}" href="/">
                        <i class="bi bi-upload me-1"></i>Analizza Log
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {% if '/dashboard' in request.path %}active{% endif %}" href="/dashboard/">
                        <i class="bi bi-grid-3x3-gap me-1"></i>Dashboard
                    </a>
                </li>
                {% if request.user.is_staff %}
                <li class="nav-item">
                    <a class="nav-link" href="/admin/" target="_blank">
                        <i class="bi bi-gear me-1"></i>Admin
                    </a>
                </li>
                {% endif %}
            </ul>
            {% if request.user.is_authenticated %}
            <ul class="navbar-nav">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i>{{ request.user.username }}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/admin/logout/?next=/admin/login/">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </a></li>
                    </ul>
                </li>
            </ul>
            {% endif %}
        </div>
    </div>
                {% if user.is_authenticated %}
                <div class="ms-auto">
                    <span class="text-white me-3">
                        <i class="bi bi-person-circle me-1"></i>
                        {{ user.username }}
                        {% if user.profile %}
                        <small class="text-white-50">({{ user.profile.get_role_display }})</small>
                        {% endif %}
                    </span>
                    <a href="{% url 'core:logout' %}" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                </div>
                {% endif %}
</nav>

<!-- Flash Messages -->
{% if messages %}
<div class="container-fluid mt-2">
    {% for message in messages %}
    <div class="alert alert-{{ message.tags|default:'info' }} alert-dismissible fade show mb-1" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endfor %}
</div>
{% endif %}

<!-- Main content -->
<main class="container-fluid py-4">
    {% block content %}{% endblock %}
</main>

<!-- Footer -->
<footer class="footer-bar text-center py-2 mt-4">
    <span>Ericsson Universal Log Analyzer &mdash; FiberCop TGS &copy; 2025</span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% block extra_js %}{% endblock %}
</body>
</html>
